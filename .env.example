# PostgreSQL (Neon, Supabase, or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/contractual?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# App URL (used by Socket.IO CORS in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Socket.IO client connects to the same origin as the custom server by default.
# Override only if the socket is on another host/port:
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# UploadThing — https://uploadthing.com/dashboard
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Stripe (optional; mock route exists)
STRIPE_SECRET_KEY=""
